rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() {
      return request.auth != null;
    }

    // For a small internal team, allow all authenticated users
    // to read/write most collections
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn();
    }

    match /attendance/{id} {
      allow read, write: if isLoggedIn();
    }

    match /leaveBalances/{id} {
      allow read, write: if isLoggedIn();
    }

    match /publicHolidays/{id} {
      allow read, write: if isLoggedIn();
    }

    match /compOffAssignments/{id} {
      allow read, write: if isLoggedIn();
    }

    match /shifts/{id} {
      allow read, write: if isLoggedIn();
    }

    match /system/{id} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }
  }
}
